<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:ctrls="using:FAControlsGallery.Controls"
             xmlns:vm="using:FAControlsGallery.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="1000"
             x:Class="FAControlsGallery.Pages.InfoBadgePage"
             x:DataType="vm:InfoBadgePageViewModel">
    <StackPanel Spacing="8">
        <ctrls:ControlExample Header="FAInfoBadge embedded in NavigationView">
            <ui:FANavigationView x:Name="nvSample1" Height="300" 
								   PaneDisplayMode="{Binding ((ComboBoxItem)SelectedItem).Content, ElementName=DisplayModeBox}">
                <ui:FANavigationView.MenuItems>
                    <ui:FANavigationViewItem Content="Home" IconSource="Home"/>
                    <ui:FANavigationViewItem Content="Account" IconSource="Contact"/>
                    <ui:FANavigationViewItem x:Name="InboxPage" Content="Inbox" IconSource="Mail">
                        <ui:FANavigationViewItem.InfoBadge>
                            <ui:FAInfoBadge x:Name="infoBadge1" Value="5"
                                          Opacity="{Binding InfoBadgeOpacity, Mode=OneWay}" />
                        </ui:FANavigationViewItem.InfoBadge>
                    </ui:FANavigationViewItem>
                </ui:FANavigationView.MenuItems>
            </ui:FANavigationView>

            <ctrls:ControlExample.Options>
                <StackPanel>
                    <CheckBox Content="InfoBadge Opacity" 
                              IsChecked="{Binding IsInfoBadgeEnabled}" />

                    <TextBlock Text="Display Mode" />
                    <ComboBox Name="DisplayModeBox" SelectedIndex="0">
                        <ComboBoxItem Content="{x:Static ui:FANavigationViewPaneDisplayMode.Left}" />
                        <ComboBoxItem Content="{x:Static ui:FANavigationViewPaneDisplayMode.LeftCompact}" />
                        <ComboBoxItem Content="{x:Static ui:FANavigationViewPaneDisplayMode.Top}" />
                    </ComboBox>
                </StackPanel>
            </ctrls:ControlExample.Options>

            <ctrls:ControlExample.XamlSource>
                <x:String xml:space="preserve">
&lt;ui:FANavigationViewItem Content="Inbox" Icon="Mail"&gt;
    &lt;ui:FANavigationViewItem.InfoBadge&gt;
        &lt;ui:FAInfoBadge Name="infoBadge1" Value="5" Opacity="$(Opacity)" /&gt;
    &lt;/ui:FANavigationViewItem.InfoBadge&gt;
&lt;/ui:FANavigationViewItem&gt;
                </x:String>
            </ctrls:ControlExample.XamlSource>

            <ctrls:ControlExample.Substitutions>
                <ctrls:ControlExampleSubstitution Key="Opacity" Value="{Binding InfoBadgeOpacity}" />
            </ctrls:ControlExample.Substitutions>
            
        </ctrls:ControlExample>

        
        <ctrls:ControlExample Header="Different FAInfoBadge Styles"
                              XamlSource="avares://FAControlsGallery/Pages/SampleCode/InfoBadge2.xaml.txt">
            <StackPanel Spacing="5">
                <TextBlock Text="Attention" />
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <ui:FAInfoBadge Classes="Attention Icon" HorizontalAlignment="Right" />
                    <ui:FAInfoBadge Classes="Attention" Value="10" HorizontalAlignment="Right" />
                    <ui:FAInfoBadge Classes="Attention Dot" VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Text="Informational" />
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <ui:FAInfoBadge Classes="Informational Icon" HorizontalAlignment="Right" />
                    <ui:FAInfoBadge Classes="Informational" Value="10" HorizontalAlignment="Right" />
                    <ui:FAInfoBadge Classes="Informational Dot" VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Text="Success" />
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <ui:FAInfoBadge Classes="Success Icon" HorizontalAlignment="Right" />
                    <ui:FAInfoBadge Classes="Success" Value="10" HorizontalAlignment="Right" />
                    <ui:FAInfoBadge Classes="Success Dot" VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Text="Caution" />
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <ui:FAInfoBadge Classes="Caution Icon" HorizontalAlignment="Right" />
                    <ui:FAInfoBadge Classes="Caution" Value="10" HorizontalAlignment="Right" />
                    <ui:FAInfoBadge Classes="Caution Dot" VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Text="Critical" />
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <ui:FAInfoBadge Classes="Critical Icon" HorizontalAlignment="Right" />
                    <ui:FAInfoBadge Classes="Critical" Value="10" HorizontalAlignment="Right" />
                    <ui:FAInfoBadge Classes="Critical Dot" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </ctrls:ControlExample>
    </StackPanel>
</UserControl>
